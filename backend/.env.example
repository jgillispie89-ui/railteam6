# Copy to .env and fill in your local values
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ironroads
PORT=3001
CORS_ORIGIN=http://localhost:5173
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=railteam6-photos
R2_PUBLIC_URL=

# Email — Resend (https://resend.com)
# Domain must be verified in the Resend dashboard before sending.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@railteam6.com
ADMIN_NOTIFY_EMAIL=americapartypodcast@gmail.com
FRONTEND_URL=https://railteam6.com

# Legacy Yahoo SMTP vars (EMAIL_USER, EMAIL_PASS) are no longer used.
# They can be removed from Render once Resend is confirmed working.
